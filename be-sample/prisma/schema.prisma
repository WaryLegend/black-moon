generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum DeliveryMethod {
  GHN
  EXPRESS
}

enum ECashBackStatus {
  ACCEPTED
  PROCESS
  DONE
}

enum EColor {
  BLACK
  WHITE
  BLUE
  GREEN
  BROWN
  PINK
  ORANGE
}

enum EMemberShip {
  MEMBER
  BRONZE
  SILVER
  GOLD
  DIAMOND
}

enum EPaymentMethod {
  COD
  VNPAY
  MOMO
  PAYPAL
  CREDIT_CARD
  BANK_TRANSFER
}

enum ESize {
  XS
  S
  M
  L
  XL
  XXL
  XXXL
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum InventoryChangeType {
  MANUAL_UPDATE
  EXCEL_IMPORT
  SALE
  RETURN
  ORDER_CANCEL
}

enum NotificationType {
  ORDER_STATUS_UPDATED
  PROMOTION_NOTIFICATION
  SYSTEM_NOTIFICATION
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPING
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PointActionType {
  EARNED
  USED
  REFUNDED
  ADDED
  SUBTRACTED
}

enum PermissionAction {
  READ
  CREATE
  UPDATE
  DELETE
  MANAGE
}

enum ReturnRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

model User {
  id                        Int                @id @default(autoincrement())
  email                     String             @unique @db.VarChar(255)
  password                  String?            @db.VarChar(255)
  activated                 Boolean            @default(false)
  activationKey             String?            @db.VarChar(50)
  activationCode            String?            @db.VarChar(6)
  activationCodeDate        DateTime?
  resetCode                 String?            @db.VarChar(6)
  codeResetDate             DateTime?
  profileCode               String?
  profileCodeDate           DateTime?
  googleId                  String?            @db.VarChar(255)
  roleId                    Int?
  defaultShippingProfileId  Int?
  lastLogin                 DateTime?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  createdBy                 String?            @db.VarChar(255)
  updatedBy                 String?            @db.VarChar(255)

  role                      Role?              @relation(fields: [roleId], references: [id])
  profile                   Profile?
  shippingProfiles          ShippingProfile[]
  defaultShippingProfile    ShippingProfile?   @relation("DefaultShippingProfile", fields: [defaultShippingProfileId], references: [id])
  reviews                   Review[]
  refreshTokens             UserRefreshToken[]
  cart                      Cart?
  orders                    Order[]
  point                     Point?
  notifications             Notification[]
  returnRequests            ReturnRequest[]
  productViewHistories      ProductViewHistory[]
  pointHistories            PointHistory[]
  customerAccount           CustomerAccount?

  @@index([createdAt])
  @@map("users")
}

model Role {
  id              Int                @id @default(autoincrement())
  name            String             @unique @db.VarChar(255)
  description     String?            @db.VarChar(255)
  active          Boolean            @default(true)
  priority        Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       String?            @db.VarChar(255)
  updatedBy       String?            @db.VarChar(255)

  permissionLinks PermissionRole[]
  users           User[]

  @@map("roles")
}

model Permission {
  id          Int               @id @default(autoincrement())
  code        String            @unique @db.VarChar(100)
  resource    String            @db.VarChar(100)
  action      PermissionAction
  description String?           @db.VarChar(255)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdBy   String?           @db.VarChar(255)
  updatedBy   String?           @db.VarChar(255)

  roleLinks   PermissionRole[]

  @@unique([resource, action])
  @@map("permissions")
}

model Profile {
  id          Int      @id @default(autoincrement())
  firstName   String?  @db.VarChar(255)
  lastName    String?  @db.VarChar(255)
  fullName    String?  @db.VarChar(255)
  birthDate   DateTime?
  phoneNumber String?  @db.VarChar(50)
  gender      Gender?
  avatarUrl   String?  @db.VarChar(500) @map("avatar_url")
  avatarName  String?  @db.VarChar(255) @map("avatar_name")
  userId      Int?     @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?  @db.VarChar(255)
  updatedBy   String?  @db.VarChar(255)

  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("profiles")
}

model UserRefreshToken {
  id           Int      @id @default(autoincrement())
  refreshToken String   @db.MediumText
  createdDate  DateTime?
  expiryDate   DateTime?
  userId       Int?

  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_refresh_tokens")
}

model TargetGroup {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(100)
  slug       String     @unique @db.VarChar(100)
  isDeleted  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  createdBy  String?    @db.VarChar(255)
  updatedBy  String?    @db.VarChar(255)

  categories Category[]

  @@map("target_groups")
}

model Category {
  id             Int                @id @default(autoincrement())
  name           String             @db.VarChar(255)
  slug           String             @unique @db.VarChar(255)
  imageUrl       String?            @db.VarChar(500)
  imageName      String?            @db.VarChar(255)
  targetGroupId  Int
  isDeleted      Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      String?            @db.VarChar(255)
  updatedBy      String?            @db.VarChar(255)

  targetGroup    TargetGroup        @relation(fields: [targetGroupId], references: [id])
  products       Product[]
  promotionLinks PromotionCategory[]

  @@index([targetGroupId])
  @@map("categories")
}

model Product {
  id             Int                @id @default(autoincrement())
  name           String?            @db.VarChar(255)
  description    String?            @db.MediumText
  slug           String?            @unique @db.VarChar(255)
  isFeatured     Boolean            @default(false)
  categoryId     Int?
  isDeleted      Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      String?            @db.VarChar(255)
  updatedBy      String?            @db.VarChar(255)

  category       Category?          @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  variants       ProductVariant[]
  reviews        Review[]
  promotionLinks PromotionProduct[]
  viewHistory    ProductViewHistory[]
  embedding      ProductEmbedding?

  @@index([isFeatured])
  @@index([createdAt])
  @@index([isDeleted])
  @@map("products")
}

model ProductVariant {
  id                 Int                @id @default(autoincrement())
  productId          Int?
  sku                String?            @unique @db.VarChar(255)
  color              EColor?
  size               ESize?
  quantity           Int?
  price              Decimal?           @db.Decimal(12, 2)
  isDeleted          Boolean            @default(false)
  version            Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  createdBy          String?            @db.VarChar(255)
  updatedBy          String?            @db.VarChar(255)

  product            Product?           @relation(fields: [productId], references: [id])
  images             ProductImage[]
  cartItems          CartItem[]
  lineItems          LineItem[]
  inventoryHistories InventoryHistory[]

  @@index([price])
  @@index([productId, price])
  @@index([isDeleted])
  @@map("product_variants")
}

model ProductImage {
  id               Int             @id @default(autoincrement())
  publicUrl        String?         @db.VarChar(500)
  gcsUrl           String?         @db.VarChar(500)
  imageOrder       Int?
  productId        Int?
  productVariantId Int?
  isDeleted        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  createdBy        String?         @db.VarChar(255)
  updatedBy        String?         @db.VarChar(255)

  product          Product?        @relation(fields: [productId], references: [id])
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@map("product_images")
}

model Promotion {
  id             Int                @id @default(autoincrement())
  name           String?            @db.VarChar(255)
  description    String?            @db.Text
  discountRate   Decimal?           @db.Decimal(5, 2)
  startDate      DateTime?
  endDate        DateTime?
  imageUrl       String?            @db.VarChar(500)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      String?            @db.VarChar(255)
  updatedBy      String?            @db.VarChar(255)

  productLinks   PromotionProduct[]
  categoryLinks  PromotionCategory[]

  @@map("promotions")
}

model Review {
  id           Int          @id @default(autoincrement())
  description  String?      @db.VarChar(255)
  rating       Float?
  published    Boolean      @default(true)
  userId       Int?
  productId    Int?
  lineItemId   Int?         @unique
  pointsEarned BigInt       @default(0)
  imageUrls    String?      @db.Text
  videoUrl     String?      @db.VarChar(1000)
  isDeleted    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  createdBy    String?      @db.VarChar(255)
  updatedBy    String?      @db.VarChar(255)

  user         User?        @relation(fields: [userId], references: [id])
  product      Product?     @relation(fields: [productId], references: [id])
  lineItem     LineItem?    @relation(fields: [lineItemId], references: [id])
  pointHistory PointHistory?

  @@index([productId, rating])
  @@index([isDeleted])
  @@map("reviews")
}

model ProductViewHistory {
  id        Int      @id @default(autoincrement())
  userId    Int?
  productId Int
  viewedAt  DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([productId])
  @@map("product_view_history")
}

model ProductEmbedding {
  productId Int      @id
  vector    String   @db.LongText
  updatedAt DateTime

  product   Product  @relation(fields: [productId], references: [id])

  @@map("product_embeddings")
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int?       @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  createdBy String?    @db.VarChar(255)
  updatedBy String?    @db.VarChar(255)

  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  @@index([userId])
  @@map("carts")
}

model CartItem {
  id               Int             @id @default(autoincrement())
  cartId           Int?
  productVariantId Int?
  quantity         Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  createdBy        String?         @db.VarChar(255)
  updatedBy        String?         @db.VarChar(255)

  cart             Cart?           @relation(fields: [cartId], references: [id])
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@index([cartId])
  @@index([productVariantId])
  @@map("cart_items")
}

model ShippingProfile {
  id          Int      @id @default(autoincrement())
  firstName   String?  @db.VarChar(255)
  lastName    String?  @db.VarChar(255)
  phoneNumber String?  @db.VarChar(50)
  address     String?  @db.VarChar(500)
  wardId      String?  @db.VarChar(50)
  ward        String?  @db.VarChar(255)
  districtId  Int?
  district    String?  @db.VarChar(255)
  provinceId  Int?
  province    String?  @db.VarChar(255)
  userId      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?  @db.VarChar(255)
  updatedBy   String?  @db.VarChar(255)

  user        User?    @relation(fields: [userId], references: [id])
  defaultFor  User[]   @relation("DefaultShippingProfile")

  @@index([userId])
  @@map("shipping_profiles")
}

model Order {
  id                   Int                @id @default(autoincrement())
  code                 String?            @unique @db.VarChar(255)
  orderDate            DateTime?
  userId               Int?
  note                 String?            @db.Text
  total                Decimal?           @db.Decimal(12, 2)
  shippingFee          Decimal?           @db.Decimal(12, 2)
  discount             Decimal?           @db.Decimal(12, 2)
  pointDiscount        Decimal?           @db.Decimal(12, 2)
  finalTotal           Decimal?           @db.Decimal(12, 2)
  paymentMethod        EPaymentMethod?
  paymentStatus        PaymentStatus?
  paymentDate          DateTime?
  status               OrderStatus?
  deliveryMethod       DeliveryMethod?
  cancelReason         String?            @db.Text
  pointsUsed           BigInt             @default(0)
  pointsEarned         BigInt             @default(0)
  shippingFirstName    String?            @db.VarChar(255)
  shippingLastName     String?            @db.VarChar(255)
  shippingFullName     String?            @db.VarChar(255)
  shippingPhoneNumber  String?            @db.VarChar(50)
  shippingAddress      String?            @db.VarChar(500)
  shippingWardId       String?            @db.VarChar(50)
  shippingWard         String?            @db.VarChar(255)
  shippingDistrictId   Int?
  shippingDistrict     String?            @db.VarChar(255)
  shippingProvinceId   Int?
  shippingProvince     String?            @db.VarChar(255)
  shippingCountry      String?            @db.VarChar(255)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  createdBy            String?            @db.VarChar(255)
  updatedBy            String?            @db.VarChar(255)

  user                 User?              @relation(fields: [userId], references: [id])
  lineItems            LineItem[]
  pointHistories       PointHistory[]
  statusHistories      OrderStatusHistory[]
  returnRequest        ReturnRequest?
  inventoryHistories   InventoryHistory[]

  @@index([userId])
  @@map("orders")
}

model LineItem {
  id               Int             @id @default(autoincrement())
  orderId          Int?
  productVariantId Int?
  quantity         Int?
  unitPrice        Decimal?        @db.Decimal(12, 2)
  discountAmount   Decimal?        @db.Decimal(12, 2)
  finalPrice       Decimal?        @db.Decimal(12, 2)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  createdBy        String?         @db.VarChar(255)
  updatedBy        String?         @db.VarChar(255)

  order            Order?          @relation(fields: [orderId], references: [id])
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
  review           Review?

  @@index([orderId])
  @@index([productVariantId])
  @@map("line_items")
}

model OrderStatusHistory {
  id              Int          @id @default(autoincrement())
  orderId         Int?
  previousStatus  OrderStatus?
  newStatus       OrderStatus?
  updateTimestamp DateTime?
  updatedBy       String?      @db.VarChar(255)
  note            String?      @db.VarChar(255)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdBy       String?      @db.VarChar(255)

  order           Order?       @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_status_history")
}

model ReturnRequest {
  id                    Int                 @id @default(autoincrement())
  orderId               Int?                @unique
  userId                Int?
  reason                String?             @db.Text
  status                ReturnRequestStatus?
  cashBackStatus        ECashBackStatus?
  originalPaymentMethod EPaymentMethod?
  bankName              String?             @db.VarChar(255)
  accountNumber         String?             @db.VarChar(255)
  accountHolderName     String?             @db.VarChar(255)
  adminComment          String?             @db.Text
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  createdBy             String?             @db.VarChar(255)
  updatedBy             String?             @db.VarChar(255)

  order                 Order?              @relation(fields: [orderId], references: [id])
  user                  User?               @relation(fields: [userId], references: [id])
  images                ReturnRequestImage[]

  @@index([orderId])
  @@index([userId])
  @@map("return_requests")
}

model ReturnRequestImage {
  id              Int             @id @default(autoincrement())
  imageUrl        String?         @db.VarChar(500)
  returnRequestId Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String?         @db.VarChar(255)
  updatedBy       String?         @db.VarChar(255)

  returnRequest   ReturnRequest?  @relation(fields: [returnRequestId], references: [id])

  @@index([returnRequestId])
  @@map("return_request_images")
}

model InventoryHistory {
  id                 Int                 @id @default(autoincrement())
  productVariantId   Int?
  changeInQuantity   Int
  quantityAfterChange Int
  typeOfChange       InventoryChangeType
  timestamp          DateTime
  orderId            Int?
  notes              String?             @db.VarChar(500)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  createdBy          String?             @db.VarChar(255)
  updatedBy          String?             @db.VarChar(255)

  productVariant     ProductVariant?     @relation(fields: [productVariantId], references: [id])
  order              Order?              @relation(fields: [orderId], references: [id])

  @@index([productVariantId])
  @@index([orderId])
  @@map("inventory_history")
}

model Notification {
  id                 Int               @id @default(autoincrement())
  userId             Int?
  title              String
  content            String?           @db.Text
  type               NotificationType?
  read               Boolean           @default(false)
  notificationDate   DateTime
  referenceIds       String?           @db.VarChar(255)
  startPromotionDate DateTime?
  endPromotionDate   DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  createdBy          String?           @db.VarChar(255)
  updatedBy          String?           @db.VarChar(255)

  user               User?             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([read])
  @@map("notifications")
}

model ScheduledNotification {
  id                 Int               @id @default(autoincrement())
  title              String
  content            String?           @db.Text
  type               NotificationType?
  referenceIds       String?           @db.VarChar(255)
  scheduledDate      DateTime
  sent               Boolean           @default(false)
  startPromotionDate DateTime?
  endPromotionDate   DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  createdBy          String?           @db.VarChar(255)
  updatedBy          String?           @db.VarChar(255)

  @@index([type])
  @@index([sent])
  @@index([scheduledDate])
  @@map("scheduled_notifications")
}

model Point {
  id                     Int      @id @default(autoincrement())
  currentPoints          BigInt   @default(0)
  totalAccumulatedPoints BigInt   @default(0)
  userId                 Int?     @unique
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  createdBy              String?  @db.VarChar(255)
  updatedBy              String?  @db.VarChar(255)

  user                   User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("points")
}

model PointHistory {
  id          Int             @id @default(autoincrement())
  points      BigInt?
  actionType  PointActionType?
  description String?         @db.VarChar(255)
  userId      Int?
  orderId     Int?
  reviewId    Int?            @unique
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   String?         @db.VarChar(255)
  updatedBy   String?         @db.VarChar(255)

  user        User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order?          @relation(fields: [orderId], references: [id])
  review      Review?         @relation(fields: [reviewId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([reviewId])
  @@map("point_histories")
}

model CustomerAccount {
  userId      Int          @id
  eMemberShip EMemberShip?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customers")
}

model PromotionProduct {
  promotionId Int
  productId   Int

  promotion   Promotion @relation(fields: [promotionId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@id([promotionId, productId])
  @@index([productId, promotionId])
  @@map("promotion_product")
}

model PromotionCategory {
  promotionId Int
  categoryId  Int

  promotion   Promotion @relation(fields: [promotionId], references: [id])
  category    Category  @relation(fields: [categoryId], references: [id])

  @@id([promotionId, categoryId])
  @@index([categoryId, promotionId])
  @@map("promotion_category")
}

model PermissionRole {
  roleId       Int
  permissionId Int

  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("permission_role")
}
